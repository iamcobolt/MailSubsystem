# MailSubsystem Configuration
# Copy this file to .env and fill in your actual values.

# ============================================================================
# REQUIRED: IMAP
# ============================================================================
IMAP_SERVER=imap.mail.me.com:993
IMAP_USERNAME=your-email@icloud.com
IMAP_PASSWORD=your-app-specific-password

# Optional IMAP TLS trust overrides. Certificate validation is strict by default.
# Use these only for private/self-hosted IMAP servers with an internal CA or
# when IMAP_SERVER connects through an IP/alias but the certificate uses another DNS name.
# IMAP_TLS_CA_CERT_FILE=/path/to/private-ca-bundle.pem
# IMAP_TLS_SERVER_NAME=mail.example.com

# ============================================================================
# REQUIRED: Database
# ============================================================================
# Default matches the companion `mailsubsystem-dev-env` PostgreSQL sandbox.
# Change host, credentials, or database name if you use another Postgres instance.
DATABASE_URL=postgresql://mailsubsystem:mailsubsystem@localhost:15432/mailsubsystem?sslmode=disable

# Or set individual vars (used when DATABASE_URL is not set):
# DB_HOST=localhost
# DB_PORT=15432
# DB_NAME=mailsubsystem
# DB_USER=mailsubsystem
# DB_PASSWORD=
# DB_SSLMODE=disable

# ============================================================================
# REQUIRED: Model providers
# ============================================================================
# Provider is auto-detected from your configuration:
#   LOCAL_LLM_URL set + API key set → hybrid (local + frontier)
#   LOCAL_LLM_URL set, no API key   → local
#   API key set, no LOCAL_LLM_URL   → that frontier provider
# Preferred model selectors use provider/model refs:
#   ANALYSIS_MODEL=<provider>/<model>   for LLM analysis/classification
#   EMBEDDING_MODEL=<provider>/<model>  for vector embeddings/search
#
# API-backed providers require either the purpose-scoped API key below or the
# provider-specific fallback key listed later in this file. Codex uses local
# `codex login`; local/OpenAI-compatible servers may use LOCAL_LLM_API_KEY.
ANALYSIS_MODEL=gemini/gemini-2.0-flash
ANALYSIS_API_KEY=your-analysis-provider-key
EMBEDDING_MODEL=gemini/gemini-embedding-001
EMBEDDING_API_KEY=your-embedding-provider-key
#
# Legacy provider override: AI_PROVIDER=hybrid|local|omlx|lmstudio|gemini|openai|anthropic|codex
# AI_PROVIDER=hybrid
# Uncomment these only if you actually have a local OpenAI-compatible model server running.
# LOCAL_LLM_ENABLED=true
# LOCAL_LLM_URL=http://localhost:1234/v1
# LOCAL_LLM_MODEL=local-model-name
# LOCAL_LLM_API_KEY=local-api-key

# Frontier (legacy, when AI_PROVIDER=hybrid or for fallback): gemini, openai, anthropic, codex
# FRONTIER_PROVIDER=gemini
# FRONTIER_MODEL=gemini-2.0-flash

# Codex subscription-backed provider (no OpenAI API key):
# 1. Run `codex login` locally with your ChatGPT/Codex account.
#    For headless hosts, use `codex login --device-auth`.
#    MailSubsystem checks `codex login status` before Codex-backed requests.
# 2. Set ANALYSIS_MODEL=codex/your-model, or use legacy AI_PROVIDER=codex + FRONTIER_MODEL.
# ANALYSIS_MODEL=codex/your-codex-model
# CODEX_BIN=codex                     # optional override; PATH is used by default
# CODEX_PROFILE=                    # optional Codex CLI profile from ~/.codex/config.toml
# CODEX_SANDBOX=read-only           # keeps Codex CLI subprocesses from editing this repo
# CODEX_TIMEOUT_SECS=300

# API keys — set at least one for frontier; keep in .env / env secrets only
# GEMINI_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
#
# Embeddings for RAG semantic search. Changing provider/model triggers reembedding.
# EMBEDDING_PROVIDER=auto              # legacy auto|local|gemini|openai
# EMBEDDING_BASE_URL=                  # optional for local/OpenAI-compatible embedding servers
# EMBEDDING_GEMINI_MODEL=gemini-embedding-001 # legacy Gemini model override
# EMBEDDING_MODEL_MISMATCH=rebuild     # auto-reset incompatible embeddings; use fail for manual rebuilds

# Optional AI tuning
# AI_ANALYSIS_MODE=standard
# AI_MAX_ITERATIONS=5
# ANALYZE_CONCURRENCY=2
# LOCATE_CONCURRENCY=2
# LOCAL_LLM_CONCURRENCY=2
# LOCATION_NATIVE_TOOLS_ENABLED=true
# API_RATE_LIMIT_RPM=60                 # initial provider-pressure guardrail; runtime adapts from signals
# GEMINI_RATE_LIMIT_RPM=
# OPENAI_RATE_LIMIT_RPM=
# ANTHROPIC_RATE_LIMIT_RPM=
#
# Optional spend safety foundation (MAIL-31 / MAIL-39 / MAIL-40).
# Current defaults are audit-only until approval enforcement is wired through
# CLI, TUI, API, and runtime provider call sites.
# SPEND_SAFETY_ENABLED=true
# SPEND_APPROVAL_MODE=audit_only          # audit_only|prompt|enforce
# SPEND_CONFIRMATION_THRESHOLD_CENTS=     # per request/batch estimate
# SPEND_DAILY_BUDGET_CENTS=
# SPEND_MONTHLY_BUDGET_CENTS=
# SPEND_PANIC_THRESHOLD_CENTS=            # rolling-window spend threshold
# SPEND_PANIC_WINDOW_SECS=300
# SPEND_PANIC_AUTO_DISABLE=true
# SPEND_AUDIT_LOG_PATH=logs/spend_approval_audit.jsonl
#
# ANALYZE_CONCURRENCY controls how many email LLM analyses run at once.
# LOCATE_CONCURRENCY controls folder recommendation concurrency.
# LOCAL_LLM_CONCURRENCY is a local-model shorthand used when either specific
# concurrency value is unset. Local-only providers default to 2; frontier
# providers default to 1.

# ============================================================================
# Optional: Local API security
# ============================================================================
# The API binds to loopback by default. Public/LAN wildcard binds are rejected.
# Tailscale addresses are allowed, but require API_AUTH_TOKEN.
# The terminal UI sends API_AUTH_TOKEN automatically when it is set.
# API_BIND=127.0.0.1:3100
# API_BIND=100.64.1.2:3100
# API_AUTH_TOKEN=generate-a-long-random-token
# Optional comma-separated scopes for API_AUTH_TOKEN. Defaults to dashboard read
# and admin for backwards-compatible single-user setups.
# API_AUTH_TOKEN_SCOPES=dashboard:read,dashboard:admin
# Set to 0 to disable the local HTTP API limiter. Health checks are excluded.
# LOCAL_API_RATE_LIMIT_RPM=120

# ============================================================================
# Optional: Core runtime
# ============================================================================
# `mailsubsystem core` / `make core` is the normal local work runtime. It starts
# the durable work coordinator without binding an HTTP server. Agents, timers,
# and manual commands enqueue work here instead of requiring a separate daemon
# pipeline. Run `mailsubsystem api` / `make api` only when a wrapper, HTTP API,
# or UI client needs one.
#
# CORE_ACCOUNT_ID=default
# CORE_WORK_POLL_INTERVAL_SECS=15
# CORE_WORK_STALE_AFTER_SECS=600
# CORE_WORK_RETRY_AFTER_SECS=60
# CORE_SHUTDOWN_GRACE_SECS=30
# CORE_ANALYZE_PAGE_SIZE=50          # internal DB page size; core drains analysis backlog continuously
# CORE_EMBED_LIMIT=50
# CORE_LOCATE_LIMIT=50
# IMAP_RAW_COMMAND_TIMEOUT_SECS=30
# SUBAGENT_SKILL_LESSON_PROMOTION_SUPPORT=2
#
# Mail Assistant heartbeat and internal sub-agent workers. Heartbeat is quiet by
# default: it enqueues work and records assistant insights rather than sending
# unsolicited chat messages.
# MAIL_ASSISTANT_HEARTBEAT=true
# MAIL_ASSISTANT_HEARTBEAT_INTERVAL_SECS=60
# MAIL_ASSISTANT_HEARTBEAT_BATCH_SIZE=50
# MAIL_ASSISTANT_SUBAGENT_CONCURRENCY=4
# MAIL_ASSISTANT_MOVE_COOLDOWN_HOURS=720
# MAIL_ASSISTANT_DIRECT_SUBAGENTS=false
#
# Keep a lightweight incremental sync lane warm while longer analysis/location
# work is running. Disable only when debugging sync deterministically.
# CORE_BACKGROUND_SYNC=true
# CORE_BACKGROUND_SYNC_INTERVAL_SECS=60
#
# Filing stays conservative by default. Core previews recommendations first and
# only enqueues the IMAP move/apply step when this is explicitly enabled.
# CORE_FILE_APPLY=false
# FOLDER_CASING_POLICY=title-case
#
# Agent DB completeness gate: request missing prerequisite work through core by
# default. Set AGENT_DB_COMPLETENESS_MODE=passive to keep the older wait-only
# behavior for debugging.
# AGENT_DB_COMPLETENESS_ENABLED=true
# AGENT_DB_COMPLETENESS_MODE=request
# AGENT_DB_COMPLETENESS_REQUEST_WORK=true
# AGENT_DB_COMPLETENESS_MAX_WAIT_SECS=120
# AGENT_DB_COMPLETENESS_INITIAL_BACKOFF_MS=500
# AGENT_DB_COMPLETENESS_MAX_BACKOFF_MS=5000
# AGENT_DB_COMPLETENESS_STABLE_POLLS=2

# ============================================================================
# Optional: Sync intervals (seconds)
# ============================================================================
# INCREMENTAL_SYNC_INTERVAL_SECS=60
# FULL_SYNC_INTERVAL_SECS=3600
# SLOW_SYNC_INTERVAL_SECS=86400
#
# Durable body sync queue workers
# BODY_SYNC_WORKERS=2
# BODY_SYNC_CLAIM_BATCH_SIZE=25
# BODY_SYNC_MAX_ATTEMPTS=5
# BODY_SYNC_RETRY_BASE_SECS=30
# BODY_SYNC_MAX_RETRY_DELAY_SECS=3600
# BODY_SYNC_STALE_PROCESSING_SECS=900
#
# Optional: Batch limits
# ============================================================================
# ANALYZE_LIMIT=50
# ANALYZE_CONCURRENCY=2
# LOCATE_LIMIT=50
# LOCATE_CONCURRENCY=2

# ============================================================================
# Optional: IMAP tuning
# ============================================================================
# IMAP_MIN_COMMAND_INTERVAL_MS=100
# IMAP_POOL_SIZE=4
# IMAP_SYNC_BATCH_SIZE=500

# ============================================================================
# Optional: Logging
# ============================================================================
# LOG_FORMAT=text
# LOG_JSON=false
# Console defaults to warnings/errors only. File logs default to info-level detail.
# LOG_CONSOLE_FILTER=warn
# LOG_FILE_FILTER=info,rig=warn,sqlx=warn
# LOG_DIR=logs
# LOG_FILE_PATH=logs/core.log
# Set LOG_FILE_PATH=off to disable file logging.
# Default filter is `info,rig=warn,sqlx=warn` to keep dependency request traces
# and database notices out of normal local file logs. Override when debugging.
# RUST_LOG=info,rig=warn,sqlx=warn
#
# Schema posture:
#   bootstrap (default): initialize an empty database, but refuse to mutate an
#     existing/stale schema without an explicit migration command.
#   auto: apply embedded schema.sql during startup whenever the schema is not current.
#   validate/manual/off: validate only; never create or migrate schema objects.
# For existing databases, review schema.sql and run `mailsubsystem migrate-schema --apply`.
# MAILSUBSYSTEM_SCHEMA_MODE=bootstrap
#
# Schema checks are skipped after the current embedded schema fingerprint is
# validated for a connection string. Re-enable checks on every DB connection only
# when debugging schema bootstrap behavior.
# MAILSUBSYSTEM_MIGRATE_EVERY_CONNECT=false
#
# Metrics sink
# Default is none for quiet local runtime logs. Use log for debugging or file
# for JSONL metrics.
# METRICS_SINK=none
# METRICS_FILE_PATH=metrics.jsonl
